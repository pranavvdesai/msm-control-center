{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "regions": ["bom1"],
  "crons": [
    {
      "path": "/api/cron/birthdays",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/cron/class-reminders",
      "schedule": "30 15 * * *"
    },
    {
      "path": "/api/cron/weekly-leave-report",
      "schedule": "30 11 * * 6"
    }
  ]
}
